generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./fpb.db"
}

// ─── ANAGRAFICA ───────────────────────────────────────────────────────────────

model Supplier {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  country   String?
  products  Product[]
  orders    Order[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id              String       @id @default(cuid())
  sku             String       @unique
  name            String
  supplierId      String
  supplier        Supplier     @relation(fields: [supplierId], references: [id])
  purchasePrice   Decimal
  marketingCredit Decimal      @default(0)
  unitsPerCarton  Int?
  unitOfSale      String       @default("CARTON")   // PIECE | CARTON | PALLET
  foodCategory    String       @default("DRY")      // DRY | LIQUID | GLASS | PERISHABLE
  fragilityClass  Int          @default(2)           // 1=base  2=medio  3=solo-cima
  isActive        Boolean      @default(true)
  notes           String?

  physical        ProductPhysical?
  customerPricing CustomerPricing[]
  shipmentLines   ShipmentLine[]
  orderLines      OrderLine[]
  priceHistory    ProductPriceHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductPriceHistory {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  oldPrice   Decimal
  newPrice   Decimal
  changedAt  DateTime @default(now())
  notes      String?

  @@index([productId])
}

model ProductPhysical {
  id              String  @id @default(cuid())
  productId       String  @unique
  product         Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Dimensioni e peso PER CARTONE (unità di spedizione)
  grossWeightKg   Decimal
  lengthCm        Decimal
  widthCm         Decimal
  heightCm        Decimal
  cartonsPerLayer Int?
  layersPerPallet Int?

  updatedAt DateTime @updatedAt
}

model Customer {
  id           String          @id @default(cuid())
  name         String          @unique
  type         String          @default("RETAIL")  // GDO | RETAIL | RESTAURANT | ETHNIC
  isActive     Boolean         @default(true)

  pricing       CustomerPricing[]
  shipmentLines ShipmentLine[]
  orders        Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── OVERHEAD E PRICING ───────────────────────────────────────────────────────

model OverheadRate {
  id           String   @id @default(cuid())
  fiscalYear   Int      @unique
  ratePct      Decimal                       // 0.2664 per il 2024
  revenueEur   Decimal?
  totalCostEur Decimal?
  notes        String?
  createdAt    DateTime @default(now())
}

model CustomerPricing {
  id                       String    @id @default(cuid())
  customerId               String
  customer                 Customer  @relation(fields: [customerId], references: [id])
  productId                String
  product                  Product   @relation(fields: [productId], references: [id])

  grossPrice               Decimal
  discount1                Decimal   @default(0)
  discount2                Decimal   @default(0)
  discount3                Decimal   @default(0)
  contractualContribPct    Decimal   @default(0)
  promotionalContribPct    Decimal   @default(0)
  promotionalActivitiesPct Decimal   @default(0)
  listingFeePct            Decimal   @default(0)
  commissionPct            Decimal   @default(0)
  netNetPrice              Decimal                  // calcolato e salvato

  validFrom DateTime  @default(now())
  validTo   DateTime?

  @@unique([customerId, productId, validFrom])
}

// ─── SPEDIZIONI ───────────────────────────────────────────────────────────────

model Shipment {
  id                    String         @id @default(cuid())
  code                  String         @unique
  legType               String                        // IMPORT | DISTRIBUTION
  carrier               String
  routeFrom             String
  routeTo               String
  shipmentDate          DateTime
  totalCostEur          Decimal
  volumetricCoefficient Decimal        @default(250)  // kg/m³
  notes                 String?

  lines     ShipmentLine[]
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShipmentLine {
  id         String    @id @default(cuid())
  shipmentId String
  shipment   Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  productId  String
  product    Product   @relation(fields: [productId], references: [id])
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  quantityCartons Int
  quantityUnits   Int

  // Calcolati dall'engine al salvataggio
  realWeightKg            Decimal
  volumeM3                Decimal
  volumetricWeightKg      Decimal
  effectiveWeightKg       Decimal  // max(real, volumetric)
  allocatedCostEur        Decimal  // totale riga
  allocatedCostPerUnitEur Decimal  // €/pezzo

  @@index([shipmentId])
  @@index([productId, customerId])
}

// ─── CONFIGURAZIONI ───────────────────────────────────────────────────────────

model PalletConfig {
  id          String  @id @default(cuid())
  name        String  @unique
  lengthCm    Int     @default(120)
  widthCm     Int     @default(80)
  maxHeightCm Int     @default(180)
  maxWeightKg Int     @default(800)
  isDefault   Boolean @default(false)
}

model AppSetting {
  key   String @id
  value String
}

// ─── AUTH ─────────────────────────────────────────────────────────────────────

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  password          String
  name              String?
  role              String             @default("USER")   // USER | ADMIN | WAREHOUSE
  createdAt         DateTime           @default(now())
  preparedOrders    Order[]
  pushSubscriptions PushSubscription[]
}

// ─── ORDINI ───────────────────────────────────────────────────────────────────

model Order {
  id            String      @id @default(cuid())
  orderNumber   String?
  type          String                        // INCOMING | OUTGOING
  status        String      @default("PENDING") // PENDING | IN_PREPARATION | READY | SHIPPED
  customerId    String?
  customer      Customer?   @relation(fields: [customerId], references: [id])
  supplierId    String?
  supplier      Supplier?   @relation(fields: [supplierId], references: [id])
  requestedDate DateTime?
  notes         String?
  warehouseNotes String?
  sourceFile    String?     // nome file PDF originale
  shipmentId    String?
  shipment      Shipment?   @relation(fields: [shipmentId], references: [id])
  preparedAt    DateTime?
  preparedById  String?
  preparedBy    User?       @relation(fields: [preparedById], references: [id])
  lines         OrderLine[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderLine {
  id               String  @id @default(cuid())
  orderId          String
  order            Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId        String
  product          Product @relation(fields: [productId], references: [id])
  quantityOrdered  Int
  quantityPrepared Int     @default(0)
  lotNumber        String?
  isPrepared       Boolean @default(false)
  notes            String?

  @@index([orderId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}
